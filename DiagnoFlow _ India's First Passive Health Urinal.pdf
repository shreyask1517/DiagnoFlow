<!DOCTYPE html>
<!-- saved from url=(0022)http://localhost:3000/ -->
<html lang="en"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
    
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DiagnoFlow | India's First Passive Health Urinal</title>
    <script src="./DiagnoFlow _ India&#39;s First Passive Health Urinal_files/lucide@latest"></script>
    <link href="./DiagnoFlow _ India&#39;s First Passive Health Urinal_files/css2" rel="stylesheet">
    <style>
        :root {
            --dark-navy: #0a0f1a;
            --teal-accent: #14f195;
            --teal-muted: rgba(20, 241, 149, 0.15);
            --glass: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 255, 255, 0.08);
            --text-main: #e2e8f0;
            --text-dim: #94a3b8;
            --mono: 'JetBrains Mono', monospace;
        }
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }
        body {
            background-color: var(--dark-navy);
            color: var(--text-main);
            line-height: 1.6;
            overflow-x: hidden;
            scroll-behavior: smooth;
        }
        .mono { font-family: var(--mono); }
        /* Background Glows */
        .glow {
            position: fixed;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(20, 241, 149, 0.07) 0%, transparent 70%);
            z-index: -1;
            pointer-events: none;
        }
        /* Navbar */
        nav {
            position: sticky;
            top: 0;
            z-index: 1000;
            background: rgba(10, 15, 26, 0.8);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--glass-border);
            padding: 1rem 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .logo {
            font-weight: 700;
            font-size: 1.5rem;
            letter-spacing: -1px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .logo span { color: var(--teal-accent); }
        .nav-links { display: flex; gap: 2rem; align-items: center; }
        .nav-links a { text-decoration: none; color: var(--text-dim); font-size: 0.9rem; transition: 0.3s; }
        .nav-links a:hover { color: var(--teal-accent); }
        .lang-toggle {
            padding: 4px 12px;
            border: 1px solid var(--glass-border);
            border-radius: 20px;
            font-size: 0.8rem;
            cursor: pointer;
        }
        /* Buttons */
        .btn {
            padding: 12px 28px;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            border: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }
        .btn-primary { background: var(--teal-accent); color: var(--dark-navy); }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 20px rgba(20, 241, 149, 0.2); }
        .btn-secondary { background: var(--glass); color: white; border: 1px solid var(--glass-border); }
        .btn-secondary:hover { background: rgba(255,255,255,0.08); }
        /* Sections */
        section { padding: 100px 5%; max-width: 1200px; margin: 0 auto; opacity: 0; transform: translateY(30px); transition: all 0.8s ease-out; }
        section.visible { opacity: 1; transform: translateY(0); }
        /* Hero */
        .hero {
            text-align: center;
            padding-top: 150px;
            min-height: 90vh;
        }
        .hero h1 { font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 1.1; margin-bottom: 1.5rem; font-weight: 800; }
        .hero p { font-size: 1.25rem; color: var(--text-dim); max-width: 600px; margin: 0 auto 2.5rem; }
        .hero-visual {
            margin-top: 4rem;
            position: relative;
            height: 300px;
            background: linear-gradient(to bottom, var(--teal-muted), transparent);
            border-radius: 40px 40px 0 0;
            border: 1px solid var(--glass-border);
            border-bottom: none;
            overflow: hidden;
        }
        /* Cards & Grid */
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-top: 3rem; }
        .card {
            background: var(--glass);
            border: 1px solid var(--glass-border);
            padding: 2.5rem;
            border-radius: 24px;
            transition: 0.3s;
        }
        .card:hover { border-color: var(--teal-accent); background: rgba(255,255,255,0.05); }
        /* Timeline */
        .timeline {
            display: flex;
            justify-content: space-between;
            margin-top: 4rem;
            position: relative;
            padding: 2rem 0;
        }
        .timeline::before { content: ''; position: absolute; top: 50%; left: 0; width: 100%; height: 2px; background: var(--glass-border); }
        .t-point { background: var(--dark-navy); position: relative; z-index: 1; padding: 0 1rem; width: 45%; }
        .t-point.bad { border-left: 4px solid #ef4444; }
        .t-point.good { border-left: 4px solid var(--teal-accent); }
        /* Stats Counter */
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; }
        .stat-item { text-align: center; padding: 2rem; }
        .stat-val { font-size: 2.5rem; font-weight: 700; color: var(--teal-accent); margin-bottom: 0.5rem; }
        /* Pricing */
        .price-card {
            border: 1px solid var(--glass-border);
            padding: 3rem 2rem;
            border-radius: 24px;
            text-align: center;
            position: relative;
        }
        .price-card.featured { border-color: var(--teal-accent); background: rgba(20, 241, 149, 0.03); transform: scale(1.05); }
        .price-val { font-size: 3rem; font-weight: 800; margin: 1.5rem 0; }
        /* WhatsApp Floating */
        .wa-float {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: #25d366;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 20px rgba(0,0,0,0.3);
            z-index: 9999;
            cursor: pointer;
        }
        /* Responsive */
        @media (max-width: 768px) {
            .nav-links { display: none; }
            .timeline { flex-direction: column; gap: 3rem; }
            .timeline::before { display: none; }
            .t-point { width: 100%; }
            .price-card.featured { transform: scale(1); }
        }
    </style>
</head>
